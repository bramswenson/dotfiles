#!/usr/bin/env bash

SCRIPT_NAME="$(basename "$0")"

show_help() {
  cat <<EOF
Usage: ${SCRIPT_NAME} [-h] [-d]

DESCRIPTION:

  Install just command runner.

OPTIONS:

  -h  Show this help message.
  -d  Enable debug mode.

EOF
}

die() {
  echo "ERROR: $*" >&2
  exit 1
}

main() {
  if ! command -v just &>/dev/null; then
    mkdir -p "${HOME}/.local/bin"
    curl --proto '=https' --tlsv1.2 -fsSf https://just.systems/install.sh \
      | bash -s -- --to "${HOME}/.local/bin"
  fi
}

while getopts "hd" opt; do
  case "${opt}" in
    d) set -x ;;
    h) show_help; exit 0 ;;
    *) show_help; exit 1 ;;
  esac
done
shift $((OPTIND - 1))

set -euo pipefail

main
