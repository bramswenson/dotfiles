#!/usr/bin/env bash

SCRIPT_NAME="$(basename "$0")"

show_help() {
  cat <<EOF
Usage: ${SCRIPT_NAME} [-h] [-d]

DESCRIPTION:

  Bootstrap a RHEL workstation for Bram Swenson.

OPTIONS:

  -h  Show this help message.
  -d  Enable debug mode.

EOF
}

die() {
  echo "ERROR: $*" >&2
  exit 1
}

CORE_GROUPS=(
  "Workstation"
  "Development Tools"
  "Console Internet Tools"
  "Graphical Administration Tools"
  "Container Management"
  "Smart Card Support"
)

CORE_PACKAGES="\
  bind-utils \
  bridge-utils \
  bzip2-libs \
  ca-certificates \
  curl \
  dnf-plugins-core \
  dnsmasq \
  figlet \
  gcc \
  git \
  git-lfs \
  gmp-devel \
  gnome-tweaks \
  gnupg \
  gnupg2 \
  htop \
  iputils \
  jq \
  libcanberra-gtk2 \
  libgtop2-devel \
  libvirt-client \
  libvirt-daemon \
  libxml2-devel \
  libxslt-devel \
  libyaml-devel \
  neovim \
  openssl-devel \
  openvpn \
  pre-commit \
  python3 \
  python3-devel \
  python3-setuptools \
  qemu-kvm \
  readline-devel \
  ruby \
  ruby-devel \
  the_silver_searcher \
  tmux \
  toilet \
  traceroute \
  tree \
  unzip \
  vim-enhanced \
  zip \
  zlib \
"

main() {
  [[ $(id -u) -eq 0 ]] && die "must not run as root"

  local -r bin_dir="${HOME}/.local/bin"
  export PATH="${bin_dir}:${PATH}"

  sudo subscription-manager repos --enable "codeready-builder-for-rhel-9-$(arch)-rpms"
  sudo dnf install -y "https://dl.fedoraproject.org/pub/epel/epel-release-latest-9.noarch.rpm" || true
  sudo dnf upgrade -y --allowerasing

  for i in "${!CORE_GROUPS[@]}"; do
    sudo dnf group install --assumeyes "${CORE_GROUPS[$i]}"
  done
  # shellcheck disable=SC2086
  sudo dnf install --assumeyes ${CORE_PACKAGES}

  for script in \
    install-aws-cli \
    install-discord \
    install-docker \
    install-gh-cli \
    install-google-cloud-sdk \
    install-just \
    install-nerd-fonts \
    install-postgresql \
    install-rustlang \
    install-slack \
    install-starship-prompt \
    install-vscode \
    install-yubikey \
  ; do
    if command -v "${script}" &>/dev/null; then
      "${script}"
    elif [ -x "${bin_dir}/${script}" ]; then
      "${bin_dir}/${script}"
    else
      echo "WARNING: ${script} not found, skipping"
    fi
  done

  for group in docker kvm; do
    sudo usermod -a -G "${group}" "${USER}" 2>/dev/null || true
  done
}

while getopts "hd" opt; do
  case "${opt}" in
    d) set -x ;;
    h) show_help; exit 0 ;;
    *) show_help; exit 1 ;;
  esac
done
shift $((OPTIND - 1))

set -euo pipefail

main
