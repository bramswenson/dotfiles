#!/usr/bin/env bash

SCRIPT_NAME="$(basename "$0")"

show_help() {
  cat <<EOF
Usage: ${SCRIPT_NAME} [-h] [-d]

DESCRIPTION:

  Install Firefox from Mozilla package repo.

OPTIONS:

  -h  Show this help message.
  -d  Enable debug mode.

EOF
}

die() {
  echo "ERROR: $*" >&2
  exit 1
}

main() {
  if [[ "$(uname)" == "Darwin" ]]; then
    if [[ ! -d "/Applications/Firefox.app" ]]; then
      local -r dmg="/tmp/firefox.dmg"
      curl -fsSL -o "${dmg}" "https://download.mozilla.org/?product=firefox-latest-ssl&os=osx&lang=en-US"
      hdiutil attach "${dmg}" -nobrowse -quiet
      cp -R "/Volumes/Firefox/Firefox.app" /Applications/
      hdiutil detach "/Volumes/Firefox" -quiet
      rm "${dmg}"
    fi
    return 0
  fi

  if [[ ! -f /etc/apt/keyrings/mozilla.gpg ]]; then
    curl -fsSL https://packages.mozilla.org/apt/repo-signing-key.gpg \
      | sudo gpg --dearmor -o /etc/apt/keyrings/mozilla.gpg
  fi
  if [[ ! -f /etc/apt/sources.list.d/mozilla.list ]]; then
    sudo tee /etc/apt/sources.list.d/mozilla.list <<EOF
deb [signed-by=/etc/apt/keyrings/mozilla.gpg] https://packages.mozilla.org/apt mozilla main
EOF
    sudo apt-get update --yes --quiet
  fi
  if [[ ! -f /etc/apt/preferences.d/mozilla ]]; then
    sudo tee /etc/apt/preferences.d/mozilla <<EOF
Package: *
Pin: origin packages.mozilla.org
Pin-Priority: 1000
EOF
  fi
  if [[ ! -f /usr/bin/firefox ]] || grep -q '#!/bin/sh' /usr/bin/firefox 2>/dev/null; then
    sudo apt install --yes --quiet firefox
  fi
}

while getopts "hd" opt; do
  case "${opt}" in
    d) set -x ;;
    h) show_help; exit 0 ;;
    *) show_help; exit 1 ;;
  esac
done
shift $((OPTIND - 1))

set -euo pipefail

main
