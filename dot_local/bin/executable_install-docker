#!/usr/bin/env bash

SCRIPT_NAME="$(basename "$0")"

show_help() {
  cat <<EOF
Usage: ${SCRIPT_NAME} [-h] [-d]

DESCRIPTION:

  Install Docker Engine and related tools.

OPTIONS:

  -h  Show this help message.
  -d  Enable debug mode.

EOF
}

die() {
  echo "ERROR: $*" >&2
  exit 1
}

ECR_CRED_HELPER_VERSION="0.7.1"

fedora() {
  if ! command -v docker &>/dev/null; then
    sudo dnf remove -y \
      docker docker-client docker-client-latest docker-common \
      docker-latest docker-latest-logrotate docker-logrotate \
      docker-selinux docker-engine-selinux docker-engine 2>/dev/null || true
    sudo dnf config-manager \
      --add-repo https://download.docker.com/linux/fedora/docker-ce.repo
    sudo dnf install -y \
      docker-ce docker-ce-cli containerd.io \
      docker-buildx-plugin docker-compose-plugin
  fi
  install_ecr_helper
}

rhel() {
  if ! command -v docker &>/dev/null; then
    sudo dnf install -y \
      docker-ce docker-ce-cli containerd.io \
      docker-buildx-plugin docker-compose-plugin
  fi
  install_ecr_helper
}

ubuntu() {
  if [[ ! -f /etc/apt/keyrings/docker.gpg ]]; then
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg \
      | sudo gpg --dearmor -o /etc/apt/keyrings/docker.gpg
  fi
  if [[ ! -f /etc/apt/sources.list.d/docker.list ]]; then
    sudo tee /etc/apt/sources.list.d/docker.list <<EOF
deb [arch="$(dpkg --print-architecture)" signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu "$(. /etc/os-release && echo "$VERSION_CODENAME")" stable
EOF
    sudo apt-get update --yes --quiet
  fi
  if ! command -v docker &>/dev/null; then
    sudo apt install --yes --quiet \
      docker-ce docker-ce-cli containerd.io \
      docker-buildx-plugin docker-compose-plugin
  fi
  if ! command -v docker-credential-ecr-login &>/dev/null; then
    sudo apt install --yes --quiet amazon-ecr-credential-helper
  fi
}

install_ecr_helper() {
  if ! command -v docker-credential-ecr-login &>/dev/null; then
    mkdir -p "${HOME}/.local/bin"
    curl -sSL -o "${HOME}/.local/bin/docker-credential-ecr-login" \
      "https://amazon-ecr-credential-helper-releases.s3.us-east-2.amazonaws.com/${ECR_CRED_HELPER_VERSION}/linux-amd64/docker-credential-ecr-login"
    chmod +x "${HOME}/.local/bin/docker-credential-ecr-login"
  fi
}

darwin() {
  if [[ ! -d "/Applications/Docker.app" ]]; then
    local arch
    if [[ "$(uname -m)" == "arm64" ]]; then
      arch="arm64"
    else
      arch="amd64"
    fi
    local -r dmg="/tmp/Docker.dmg"
    curl -fsSL -o "${dmg}" "https://desktop.docker.com/mac/main/${arch}/Docker.dmg"
    hdiutil attach "${dmg}" -nobrowse -quiet
    cp -R "/Volumes/Docker/Docker.app" /Applications/
    hdiutil detach "/Volumes/Docker" -quiet
    rm "${dmg}"
  fi
}

main() {
  if [[ "$(uname)" == "Darwin" ]]; then
    darwin
    return 0
  fi

  case "$(lsb_release -is 2>/dev/null)" in
    RedHatEnterprise) rhel ;;
    Ubuntu) ubuntu ;;
    Fedora) fedora ;;
    *) die "unsupported distro" ;;
  esac
  sudo systemctl enable --now docker.service
}

while getopts "hd" opt; do
  case "${opt}" in
    d) set -x ;;
    h) show_help; exit 0 ;;
    *) show_help; exit 1 ;;
  esac
done
shift $((OPTIND - 1))

set -euo pipefail

main
