[user]
  name = {{ .name }}
  email = {{ .email }}
  signingkey = {{ .gpg_signing_key }}

[github]
  user = bramswenson

[core]
  whitespace = fix,-indent-with-non-tab,trailing-space,cr-at-eol
  excludesfile = ~/.gitignore_global
{{- if eq .chezmoi.os "darwin" }}
  editor = "/opt/homebrew/bin/vim -v"
{{- else }}
  editor = "/usr/bin/vim -v"
{{- end }}
  commentchar = ";"

[color]
  ui = auto

[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green

[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red bold
  new = green bold

[color "status"]
  added = green
  changed = magenta
  untracked = red
  branch = green

[alias]
  s = status
  g = log --graph --decorate --pretty=oneline --abbrev-commit --no-show-signature
  ga = log --graph --decorate --pretty=oneline --abbrev-commit --all
  ci = commit
  br = branch
  co = checkout
  df = diff
  dc = diff --cached
  ls = ls-files
  ign = ls-files -o -i --exclude-standard
  ctags = !.git/hooks/ctags
  brs = branch --sort=committerdate
[rerere]
  enabled = true
[commit]
  # NOTE: gpg --edit-key -> trust -> ultimate
  gpgsign = true
[log]
  showsignature = true
[init]
  defaultBranch = main
[pull]
  rebase = true
[filter "lfs"]
  process = git-lfs filter-process
  required = true
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
