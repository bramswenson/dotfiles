# PATH configuration
# Managed by chezmoi — edits will be overwritten

# Guard against duplicate PATH entries on re-source (tmux panes, nested shells)
_path_prepend() { case ":${PATH}:" in *:"$1":*) ;; *) export PATH="$1:${PATH}" ;; esac; }
_path_append()  { case ":${PATH}:" in *:"$1":*) ;; *) export PATH="${PATH}:$1" ;; esac; }

# User local binaries
_path_prepend "${HOME}/.local/bin"

# Rust/Cargo (cargo install binaries)
if [ -f "${HOME}/.cargo/env" ]; then
  source "${HOME}/.cargo/env"
fi

# Krew (kubectl plugin manager)
_path_prepend "${HOME}/.krew/bin"

{{- if eq .chezmoi.os "linux" }}
# PostgreSQL (Linux — RHEL/Fedora pgdg packages)
# Finds the highest installed pgsql version automatically
for pgdir in /usr/pgsql-*/bin; do
  if [ -d "${pgdir}" ]; then
    _path_prepend "${pgdir}"
  fi
done
{{- end }}

{{- if eq .chezmoi.os "darwin" }}
# Homebrew
eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null || /usr/local/bin/brew shellenv 2>/dev/null)"
{{- end }}

unset -f _path_prepend _path_append
